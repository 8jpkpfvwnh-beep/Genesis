<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>G & A Wedding</title>
    <style>
        :root {
            --bg: #f8f9fa;
            --text: #2d3436;
            --accent: #636e72;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); text-align: center; margin: 0; padding: 20px; }
        .card { background: white; border-radius: 15px; padding: 25px; margin-bottom: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        h1 { font-weight: 300; letter-spacing: 2px; }
        .btn { display: inline-block; background: var(--text); color: white; padding: 12px 25px; border-radius: 25px; text-decoration: none; margin-top: 10px; }
        .address { font-style: italic; color: var(--accent); }
    </style>
</head>
<body>

    <div class="card">
        <h1>Genesis & Alexis</h1>
        <p>10 . 13 . 2026</p>
    </div>

    <div class="card">
        <h3>The Venue</h3>
        <p class="address">11559 W Lee Ln<br>Youngtown, AZ 85363</p>
        <a href="https://maps.google.com/?q=11559+W+Lee+Ln+Youngtown+AZ+85363" class="btn">Open Maps</a>
    </div>

    <div class="card">
        <h3>RSVP</h3>
        <p>Kindly respond by September 1st.</p>
        <a href="#" class="btn">Submit RSVP</a>
    </div>

</body>
</html>
